{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "!node_modules",
      "!.next",
      "!dist",
      "!build",
      "!public/showpiece",
      "!src/showpiece/__fixtures__"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "globals": ["Float16Array"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "noUselessReturn": "off"
      },
      "performance": {
        "noAwaitInLoops": "off",
        "noJsxPropsBind": "off",
        "noSyncScripts": "off"
      },
      "style": {
        "noIncrementDecrement": "off",
        "useConsistentMethodSignatures": "off",
        "useDestructuring": "off"
      },
      "suspicious": {
        "noEqualsToNull": "off",
        "noUnknownAttribute": "off",
        "noUnnecessaryConditions": "off",
        "noShadow": "off",
        "noUnknownAtRules": "off"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "noDuplicateClasses": "off",
        "organizeImports": "on",
        "useSortedAttributes": "off",
        "useSortedInterfaceMembers": "off",
        "useSortedKeys": "off",
        "useSortedProperties": "off"
      }
    }
  },
  "extends": ["ultracite/biome/core", "ultracite/biome/next"]
}
